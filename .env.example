# ⚙️ Variables d'Environnement - ONPS Site
# Copier ce fichier vers .env.local et remplir les valeurs

# 🗄️ Turso Database Configuration
# Obtenir les valeurs depuis https://app.turso.io
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your_token_here

# 📱 Environment
NODE_ENV=production

# 🔐 Admin Credentials (optionnel - defaults à admin/admin123)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# 🌐 Site Configuration
NEXT_PUBLIC_SITE_URL=https://votre-domaine.netlify.app

# 📧 Email Configuration (pour contact form - optionnel)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# 🔔 Notifications (optionnel)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
